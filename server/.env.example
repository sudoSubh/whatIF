# ============================================================================
# WhatIF server environment variables
# ============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env.
#
# For full deployment instructions see ../DEPLOY.md
# ============================================================================

# Where Express listens. Render sets this automatically — leave unset there.
PORT=3001

# development | test | production
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (Supabase Postgres)
# ----------------------------------------------------------------------------
# Get both URLs from Supabase Dashboard → Project Settings → Database →
# "Connection string". Use the URI tab and replace [YOUR-PASSWORD].
#
# DATABASE_URL  — pooled connection (port 6543, "?pgbouncer=true&connection_limit=1")
#                 used by the running app
# DIRECT_URL    — direct connection (port 5432)
#                 used by `prisma migrate`; leave blank for non-pooled DBs
# ----------------------------------------------------------------------------

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=""

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=""


# ----------------------------------------------------------------------------
# JWT — token signing. Must be >=32 chars; CHANGE FROM THE EXAMPLE BELOW.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ----------------------------------------------------------------------------
# Gemini AI — https://aistudio.google.com/apikey
# Required in production; AI features are disabled gracefully if unset locally.
# ----------------------------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# CORS — your deployed client URL (e.g. https://your-app.vercel.app).
# Required in production. Leave blank in dev (server defaults to localhost:5173).
# ----------------------------------------------------------------------------
FRONTEND_URL=
