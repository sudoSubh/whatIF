# ============================================================================
# WhatIF server environment variables
# ============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env.
#
# For full deployment instructions see ../DEPLOY.md
# ============================================================================

# Where Express listens. Render sets this automatically — leave unset there.
PORT=3001

# development | test | production
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (Supabase Postgres)
# ----------------------------------------------------------------------------
# Prisma connects via Postgres URLs — NOT the Supabase API keys below.
#
# Option A (recommended): set SUPABASE_URL + SUPABASE_DB_PASSWORD and leave
# DATABASE_URL / DIRECT_URL blank — they are built automatically.
#   DB password: Supabase Dashboard → Project Settings → Database → password
#   (reset there if you don't have it; it is NOT the secret/publishable key)
#
# Option B: paste full connection strings from Dashboard → Database → URI:
#   DATABASE_URL  — pooled (port 6543, ?pgbouncer=true&connection_limit=1)
#   DIRECT_URL    — direct (port 5432), used by prisma migrate
# ----------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
# Database password from Supabase (NOT the secret key above)
SUPABASE_DB_PASSWORD=
# Optional: e.g. ap-south-1 — enables pooled DATABASE_URL on port 6543
SUPABASE_REGION=

DATABASE_URL=
DIRECT_URL=
# ----------------------------------------------------------------------------
# JWT — token signing. Must be >=32 chars; CHANGE FROM THE EXAMPLE BELOW.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ----------------------------------------------------------------------------
# Gemini AI — https://aistudio.google.com/apikey
# Required in production; AI features are disabled gracefully if unset locally.
# GEMINI_API_KEY_FALLBACK is optional — used only when the primary key hits
# quota/rate-limit/auth/server errors after all model fallbacks are exhausted.
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_API_KEY_FALLBACK=

# ----------------------------------------------------------------------------
# CORS — your deployed client URL (e.g. https://your-app.vercel.app).
# Required in production. Leave blank in dev (server defaults to localhost:5173).
# ----------------------------------------------------------------------------
FRONTEND_URL=
