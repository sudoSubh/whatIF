{
  "name": "whatif-server",
  "version": "1.0.0",
  "description": "WhatIF API Server - Future Timeline Simulation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/setup-prisma-env.js && prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "node scripts/setup-prisma-env.js && node dist/index.js",
    "db:generate": "node scripts/setup-prisma-env.js && prisma generate",
    "db:push": "node scripts/setup-prisma-env.js && prisma db push",
    "db:migrate": "node scripts/setup-prisma-env.js && prisma migrate dev",
    "db:deploy": "node scripts/setup-prisma-env.js && prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "node scripts/setup-prisma-env.js && prisma generate",
    "test": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
